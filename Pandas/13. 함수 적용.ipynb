    "def add_cm(height):\n",
    "    return str(height) + 'cm'\n",
    "\n",
    "df['키'] = df['키'].apply(add_cm) # 키 데이터에 대해서 add_cm 함수를 호출한 결과 데이터를 반영\n",
    "df"
